# 🌐 4. index.php (FULL WORKING CODE)

```php
<?php include 'db.php'; ?>

<h2>Add Patient</h2>
<form method="post">
    Pid: <input type="number" name="pid"><br>
    Name: <input type="text" name="pname"><br>
    DOB: <input type="date" name="dob"><br>
    Contact: <input type="text" name="contact"><br>
    Address: <input type="text" name="address"><br>
    <input type="submit" name="add_patient">
</form>

<h2>Add Diagnosis</h2>
<form method="post">
    Did: <input type="number" name="did"><br>
    Name: <input type="text" name="dname"><br>
    Medication: <input type="text" name="med"><br>
    Department: <input type="text" name="dept"><br>
    <input type="submit" name="add_diagnosis">
</form>

<h2>Assign Treatment</h2>
<form method="post">
    Patient ID: <input type="number" name="t_pid"><br>
    Diagnosis ID: <input type="number" name="t_did"><br>
    Type: <input type="text" name="type"><br>
    Doctor Name: <input type="text" name="doctor"><br>
    <input type="submit" name="assign_treatment">
</form>

<h2>Update Patient</h2>
<form method="post">
    Pid: <input type="number" name="u_pid"><br>
    New Name: <input type="text" name="u_name"><br>
    <input type="submit" name="update">
</form>

<h2>Delete Patient</h2>
<form method="post">
    Pid: <input type="number" name="d_pid"><br>
    <input type="submit" name="delete">
</form>

<hr>

<?php

// ADD PATIENT
if(isset($_POST['add_patient'])){
    $sql = "INSERT INTO PATIENT VALUES(
        $_POST[pid],
        '$_POST[pname]',
        '$_POST[dob]',
        '$_POST[contact]',
        '$_POST[address]'
    )";

    echo $conn->query($sql) ? "Patient Added<br>" : $conn->error;
}

// ADD DIAGNOSIS
if(isset($_POST['add_diagnosis'])){
    $sql = "INSERT INTO DIAGNOSIS VALUES(
        $_POST[did],
        '$_POST[dname]',
        '$_POST[med]',
        '$_POST[dept]'
    )";

    echo $conn->query($sql) ? "Diagnosis Added<br>" : $conn->error;
}

// ASSIGN TREATMENT
if(isset($_POST['assign_treatment'])){
    $sql = "INSERT INTO TREATMENT VALUES(
        $_POST[t_pid],
        '$_POST[type]',
        $_POST[t_did],
        '$_POST[doctor]'
    )";

    echo $conn->query($sql) ? "Treatment Assigned<br>" : $conn->error;
}

// UPDATE PATIENT
if(isset($_POST['update'])){
    $sql = "UPDATE PATIENT 
            SET Pname='$_POST[u_name]' 
            WHERE Pid=$_POST[u_pid]";

    echo $conn->query($sql) ? "Patient Updated<br>" : $conn->error;
}

// DELETE PATIENT
if(isset($_POST['delete'])){
    $sql = "DELETE FROM PATIENT WHERE Pid=$_POST[d_pid]";

    echo $conn->query($sql) ? "Patient Deleted<br>" : $conn->error;
}

?>
```

